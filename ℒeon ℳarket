    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        body {
            background-color: #05050a;
            color: #e2e2e9;
            line-height: 1.6;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* Ornamen Cahaya Latar Belakang */
        .bg-glow-1 {
            position: absolute;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(138, 43, 226, 0.12) 0%, rgba(0,0,0,0) 70%);
            top: -150px;
            left: -150px;
            z-index: 1;
        }
        .bg-glow-2 {
            position: absolute;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(3, 218, 198, 0.08) 0%, rgba(0,0,0,0) 70%);
            bottom: -150px;
            right: -150px;
            z-index: 1;
        }

        .container {
            width: 100%;
            max-width: 500px;
            background: rgba(13, 13, 22, 0.75);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 32px;
            padding: 30px 20px;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.8);
            z-index: 2;
        }

        /* Header */
        .header {
            text-align: center;
            margin-bottom: 30px;
            position: relative;
        }

        .header h1 {
            font-size: 2.6rem;
            font-weight: 800;
            background: linear-gradient(135deg, #ffffff 40%, #a370f7 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 4px;
        }

        .header p {
            font-size: 0.75rem;
            color: #6d6d85;
            letter-spacing: 3px;
            text-transform: uppercase;
            font-weight: 700;
        }

        /* Kategori */
        .category-title {
            font-size: 0.85rem;
            color: #a370f7;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin: 35px 0 15px 4px;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 8px;
            border-bottom: 1px solid rgba(163, 112, 247, 0.2);
            padding-bottom: 6px;
        }

        /* Kotak Produk */
        .product-box {
            background: rgba(255, 255, 255, 0.015);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-radius: 22px;
            padding: 18px;
            margin-bottom: 16px;
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), border-color 0.3s, box-shadow 0.3s;
        }

        .product-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 15px;
        }

        .product-title-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* Logo Aplikasi */
        .app-logo {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: #fff;
            box-shadow: 0 4px 10px rgba(0,0,0,0.4);
        }

        .product-name {
            font-size: 1.05rem;
            font-weight: 700;
            color: #ffffff;
        }

        /* Badge Stok Digital */
        .stock-badge {
            font-size: 0.7rem;
            font-weight: 700;
            padding: 4px 8px;
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .stock-ready {
            background: rgba(39, 174, 96, 0.15);
            color: #2ecc71;
            border: 1px solid rgba(39, 174, 96, 0.3);
        }
        .stock-ask {
            background: rgba(241, 196, 15, 0.15);
            color: #f1c40f;
            border: 1px solid rgba(241, 196, 15, 0.3);
        }

        /* Sub Grup */
        .sub-group {
            margin-bottom: 12px;
            border-left: 2px solid rgba(255, 255, 255, 0.06);
            padding-left: 12px;
            margin-left: 4px;
        }

        .sub-title {
            font-size: 0.75rem;
            color: #8e8e9f;
            font-weight: 700;
            margin-bottom: 4px;
        }

        /* Detail Harga */
        .price-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.88rem;
            padding: 4px 0;
            color: #b5b5c6;
        }

        .price-value {
            font-family: monospace;
            font-weight: 700;
            font-size: 0.85rem;
            color: #03dac6;
            background: rgba(3, 218, 198, 0.06);
            padding: 2px 7px;
            border-radius: 6px;
            border: 1px solid rgba(3, 218, 198, 0.1);
